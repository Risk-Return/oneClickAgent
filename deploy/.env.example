# Cloud Gateway environment variables (copy to .env)
IAGENT_DB_URL=postgres://iagent:changeme@localhost:5432/iagent
IAGENT_JWT_SECRET=replace-with-256-bit-hex
IAGENT_FILE_STORE=local:./data/files
IAGENT_HTTP_ADDR=:8080
IAGENT_ACCESS_TTL=15m
IAGENT_REFRESH_TTL=720h
IAGENT_MAX_UPLOAD_MB=100
IAGENT_HEARTBEAT_S=15
IAGENT_AGENTS_PER_USER=1
